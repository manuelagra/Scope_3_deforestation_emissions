## 2) Helper utilities
- master-grid metadata (CRS/transform/shape/pixel area)
- robust reproject to master (categorical / nearest)
- block window iterator


# --- 2) Helpers ---

def get_master_profile(master_path: Path):
    with rasterio.open(master_path) as ds:
        profile = ds.profile.copy()
        transform = ds.transform
        crs = ds.crs
        height, width = ds.height, ds.width

        # Pixel area in hectares (best effort):
        # For projected CRS in meters: pixel_area_m2 = |a * e| where transform = (a, b, c, d, e, f)
        a = transform.a
        e = transform.e
        pixel_area_m2 = abs(a * e)
        pixel_area_ha = pixel_area_m2 / 10000.0
        return profile, (crs, transform, height, width, pixel_area_ha)

def iter_block_windows(height, width, block_size=1024):
    for row_off in range(0, height, block_size):
        h = min(block_size, height - row_off)
        for col_off in range(0, width, block_size):
            w = min(block_size, width - col_off)
            yield Window(col_off, row_off, w, h)

def reproject_to_master(src_path: Path, master_meta, resampling=Resampling.nearest, src_nodata=None, dst_nodata=None):
    """Reproject a full raster into master grid (in-memory array).
    Use only for smaller rasters; for large rasters, prefer block-wise reproject.
    """
    crs_m, transform_m, height_m, width_m, _ = master_meta
    dst = np.full((height_m, width_m), dst_nodata if dst_nodata is not None else 0, dtype=np.float32)

    with rasterio.open(src_path) as src:
        reproject(
            source=rasterio.band(src, 1),
            destination=dst,
            src_transform=src.transform,
            src_crs=src.crs,
            src_nodata=src_nodata if src_nodata is not None else src.nodata,
            dst_transform=transform_m,
            dst_crs=crs_m,
            dst_nodata=dst_nodata,
            resampling=resampling
        )
    return dst

